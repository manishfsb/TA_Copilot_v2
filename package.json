{
  "name": "autograder-v2",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --kill-others-on-fail --prefix '[{name}]' --prefix-colors 'cyan,green' --names 'backend,frontend' '.venv/bin/uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000' 'npm run dev --prefix frontend'",
    "stop": "lsof -ti:8000,5173 | xargs kill -9 2>/dev/null; echo 'Servers stopped.'",
    "backup": "bash ./scripts/backup_db.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
